-- ===================== HELPERS =====================

-- Get enemy folder safely
local function getEnemyFolder()
    local world = workspace:FindFirstChild(SelectedWorld)
    if world then
        return world:FindFirstChild("Enemy")
    end
end

-- Get enemies (supports weird structures)
local function getAllEnemies()
    local folder = getEnemyFolder()
    if not folder then return {} end

    local list = {}

    for _, obj in ipairs(folder:GetChildren()) do
        if obj:IsA("Model") then
            table.insert(list, obj)
        end
    end

    return list
end

-- Unique names
local function getUniqueEnemies()
    local seen = {}
    local list = {}

    for _, enemy in ipairs(getAllEnemies()) do
        if not seen[enemy.Name] then
            seen[enemy.Name] = true
            table.insert(list, enemy.Name)
        end
    end

    return list
end

-- Get enemies by name
local function getEnemiesByName(name)
    local list = {}

    for _, enemy in ipairs(getAllEnemies()) do
        if enemy.Name == name then
            table.insert(list, enemy)
        end
    end

    return list
end

-- Teleport
local function teleportToEnemy(enemy)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    local hrp = char.HumanoidRootPart

    local target = enemy:FindFirstChild("HumanoidRootPart")
        or enemy.PrimaryPart
        or enemy:FindFirstChild("Head")

    if target then
        hrp.CFrame = target.CFrame * CFrame.new(0, 0, -3)
    end
end

-- HP
local function getEnemyHP(enemy)
    local attr = enemy:GetAttribute("CurrentHP")

    if typeof(attr) == "string" then
        local _, hp = string.match(attr, "([^;]+);([^;]+)")
        return tonumber(hp) or 0
    end

    return 0
end

